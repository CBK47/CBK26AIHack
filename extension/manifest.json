{
  "manifest_version": 3,
  "name": "AI Mission Control",
  "version": "0.1.0",
  "description": "A cinematic data visualization experience for your AI usage.",
  "action": {
    "default_popup": "popup/popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://chatgpt.com/*",
        "*://claude.ai/*",
        "*://kimi.moonshot.cn/*",
        "*://www.kimi.com/*"
      ],
      "js": [
        "content.js"
      ]
    }
  ],
  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://chatgpt.com/*",
    "*://claude.ai/*",
    "*://kimi.moonshot.cn/*",
    "*://www.kimi.com/*"
  ]
}